---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  index: string;
  chapter: number;
  chapterName: string;
  heroImage?: string;
  subtitle?: string;
  keywords?: string[];
  cuisine?: string;
  style?: string;
  recipeType?: string;
  prevRecipe?: { slug: string; title: string } | null;
  nextRecipe?: { slug: string; title: string } | null;
}

const { title, index, chapter, chapterName, heroImage, subtitle, keywords = [], cuisine = '', style: recipeStyle = '', recipeType = 'recipe', prevRecipe, nextRecipe } = Astro.props;
const hasHero = heroImage && heroImage.length > 0;

let sectionHref = '/brigade';
let sectionName = 'The Brigade';

if (chapter === 1 || chapter === 2) {
  sectionHref = '/academy';
  sectionName = 'The Academy';
} else if (chapter === 10 || chapter === 11 || chapter === 12) {
  sectionHref = '/larder';
  sectionName = 'The Larder';
}
---

<BaseLayout title={title} description={`${title} — Chapter ${chapter}: ${chapterName}. From Café Athena — The Manual.`}>
  <article class="max-w-4xl mx-auto px-6 py-12 md:py-20 lg:py-24">
    
    <!-- Render floating recipe card -->
    <div class="glass-panel rounded-2xl overflow-hidden relative z-10 recipe-card opacity-0 translate-y-12">
      
      <!-- Breadcrumbs -->
      <nav class="bg-white/40 border-b border-[#e0d8cc] px-6 py-4 md:px-10 flex flex-wrap items-center gap-2 text-sm font-medium text-[#6b6b7b] uppercase tracking-wider" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[#c9a96e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm transition-colors">Home</a>
        <span class="text-[#e0d8cc]">/</span>
        <a href={sectionHref} class="hover:text-[#c9a96e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm transition-colors">{sectionName}</a>
        <span class="text-[#e0d8cc]">/</span>
        <a href={`${sectionHref}#chapter-${chapter}`} class="hover:text-[#c9a96e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm transition-colors">Ch. {chapter}</a>
        <span class="text-[#e0d8cc]">/</span>
        <span class="text-[#1a1a2e]">{index}</span>
      </nav>

      <!-- Hero Image -->
      {hasHero ? (
        <div class="relative w-full h-[400px] md:h-[500px] overflow-hidden bg-[#1a1a2e]">
          <div class="absolute inset-0 bg-[#1a1a2e]/20 z-10 pointer-events-none"></div>
          <img
            class="recipe-hero-img w-full h-full object-cover object-center"
            src={heroImage}
            alt={title}
            loading="eager"
          />
        </div>
      ) : (
        <div class="w-full h-[200px] bg-gradient-to-b from-[#f0ece3] to-[#e8e2d9] flex flex-col items-center justify-center border-b border-[#e0d8cc] gap-2">
          <p class="font-heading text-7xl font-bold text-[#1a1a2e]/[0.06] leading-none tracking-tighter select-none">{index}</p>
          <p class="font-heading italic text-[10px] text-[#c9a96e]/40 tracking-[0.3em] uppercase select-none">Café Athena</p>
        </div>
      )}

      <!-- Recipe Content Area -->
      <div class="p-6 md:p-12 lg:p-16 bg-[#faf7f2]/90">
        
        <header class="mb-12 text-center recipe-header opacity-0">
          <p class="font-bold text-xs tracking-widest uppercase text-[#c9a96e] mb-4">
            Chapter {chapter} · {chapterName}
          </p>
          <h1 class="font-heading text-5xl md:text-6xl font-bold text-[#1a1a2e] tracking-tight mb-6">
            {title}
          </h1>
          {subtitle && <p class="font-heading text-2xl italic text-[#6b6b7b] max-w-2xl mx-auto">{subtitle}</p>}
        </header>

        <div class="w-16 h-0.5 bg-[#e0d8cc] mx-auto mb-8"></div>

        <!-- Metadata tags -->
        {(recipeType === 'technique' || cuisine || recipeStyle || keywords.length > 0) && (
          <div class="flex flex-wrap gap-2 justify-center mb-12">
            {recipeType === 'technique' && (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase bg-[#1a1a2e] text-[#f5f0e8]">Technique</span>
            )}
            {cuisine && (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wide uppercase bg-[#c9a96e]/10 text-[#a8873f] border border-[#c9a96e]/20">{cuisine}</span>
            )}
            {recipeStyle && (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wide uppercase bg-[#1a1a2e]/5 text-[#1a1a2e]/50 border border-[#1a1a2e]/10">{recipeStyle}</span>
            )}
            {keywords.map(kw => (
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white border border-[#e0d8cc] text-[#6b6b7b]">{kw}</span>
            ))}
          </div>
        )}

        <!-- Markdown Body -->
        <div
          class="prose prose-lg mx-auto prose-headings:font-heading prose-headings:font-bold prose-headings:text-[#1a1a2e] prose-h2:text-3xl prose-h3:text-2xl prose-p:text-[#2d2d44] prose-p:leading-relaxed prose-a:text-[#c9a96e] prose-a:no-underline hover:prose-a:underline prose-li:text-[#2d2d44] prose-strong:text-[#1a1a2e]"
          data-pagefind-body
          data-pagefind-meta={`title:${title}, chapter:Chapter ${chapter} – ${chapterName}${cuisine ? `, cuisine:${cuisine}` : ''}${recipeStyle ? `, style:${recipeStyle}` : ''}`}
        >
          {keywords.length > 0 && (
            <span data-pagefind-filter={`cuisine[${cuisine}], style[${recipeStyle}]`} class="hidden" aria-hidden="true">
              {keywords.join(', ')}
            </span>
          )}
          <slot />
        </div>

      </div>

      <!-- Footer Navigation -->
      <nav class="bg-[#1a1a2e] px-6 py-8 md:px-12 flex flex-col md:flex-row justify-between items-center gap-6" aria-label="Recipe navigation">
        {prevRecipe ? (
          <a href={`/${prevRecipe.slug}`} class="group flex flex-col items-start w-full md:w-1/2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm">
            <span class="text-xs font-bold tracking-widest uppercase text-[#6b6b7b] group-hover:text-[#c9a96e] transition-colors mb-2">← Previous</span>
            <span class="font-heading text-xl md:text-2xl text-white group-hover:text-[#c9a96e] transition-colors text-left line-clamp-1">{prevRecipe.title}</span>
          </a>
        ) : <div class="w-full md:w-1/2"></div>}
        
        {nextRecipe ? (
          <a href={`/${nextRecipe.slug}`} class="group flex flex-col items-end w-full md:w-1/2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm">
            <span class="text-xs font-bold tracking-widest uppercase text-[#6b6b7b] group-hover:text-[#c9a96e] transition-colors mb-2">Next →</span>
            <span class="font-heading text-xl md:text-2xl text-white group-hover:text-[#c9a96e] transition-colors text-right line-clamp-1">{nextRecipe.title}</span>
          </a>
        ) : <div class="w-full md:w-1/2"></div>}
      </nav>

    </div>
  </article>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    document.addEventListener('DOMContentLoaded', () => {
      gsap.registerPlugin(ScrollTrigger);
      
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        
        // Entrance animation
        const tl = gsap.timeline();
        tl.to('.recipe-card', { y: 0, opacity: 1, duration: 1, ease: 'power3.out' })
          .to('.recipe-header', { opacity: 1, duration: 0.8 }, "-=0.5");

        // Parallax image
        const heroImg = document.querySelector('.recipe-hero-img');
        if (heroImg) {
          // Scale it up slightly so it can parallax downwards without showing background
          gsap.set(heroImg, { scale: 1.1 });
          gsap.to(heroImg, {
            yPercent: 15,
            ease: 'none',
            scrollTrigger: {
              trigger: '.recipe-card',
              start: 'top bottom',
              end: 'bottom top',
              scrub: true
            }
          });
        }
      } else {
        document.querySelector('.recipe-card')?.classList.remove('opacity-0', 'translate-y-12');
        document.querySelector('.recipe-header')?.classList.remove('opacity-0');
      }
    });
  </script>
</BaseLayout>

<style is:global>
  .ref-image {
    margin: 2rem 0;
    width: 100%;
    overflow: hidden;
    text-align: center;
  }

  .ref-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .ref-image figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-style: italic;
    color: #6b6b7b;
  }
</style>
