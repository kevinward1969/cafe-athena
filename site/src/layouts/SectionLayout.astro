---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Chapter {
  num: number;
  name: string;
  desc: string;
  recipes: CollectionEntry<'recipes'>[];
}

interface Props {
  title: string;
  subtitle: string;
  part: string;
  currentPage: string;
  chapters: Chapter[];
  bannerImage?: string;
}

const { title, subtitle, part, currentPage, chapters, bannerImage } = Astro.props;
---

<BaseLayout title={title} description={`${title} — ${subtitle}`} currentPage={currentPage}>
  <div class="max-w-7xl mx-auto px-6 py-16">
    
    <!-- Section Hero -->
    <section class="text-center mb-20 section-hero opacity-0 translate-y-8">
      <p class="font-heading text-xl md:text-2xl italic text-[#6b6b7b] mb-4">Part {part}</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-[#1a1a2e] tracking-tight mb-6">{title}</h1>
      <p class="text-lg md:text-xl text-[#6b6b7b] max-w-2xl mx-auto">{subtitle}</p>
      <div class="w-16 h-0.5 bg-[#c9a96e] mx-auto mt-8"></div>
    </section>

    <!-- Section Banner -->
    {bannerImage && (
      <div class="w-screen relative left-1/2 -translate-x-1/2 mb-16 overflow-hidden" style="max-height: 480px;">
        <img
          src={bannerImage}
          alt=""
          aria-hidden="true"
          class="w-full h-full object-cover"
          style="max-height: 480px;"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-x-0 bottom-0 h-16" style="background: linear-gradient(to bottom, transparent, #faf7f2);"></div>
      </div>
    )}

    <!-- Chapters Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" style="margin-bottom: 7rem;">
      {chapters.map((ch, i) => (
        <a 
          href={`#chapter-${ch.num}`}
          class="chapter-card perspective-container group focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-[#c9a96e] rounded-xl"
        >
          <div class="isometric-card glass-panel h-full p-8 rounded-xl flex flex-col items-start transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(26,26,46,0.1)] border-l-4 border-l-[#c9a96e]">
            <span class="font-heading text-5xl md:text-6xl font-bold text-[#ede6d8] mb-4 drop-shadow-sm transition-transform duration-500 group-hover:scale-110 origin-left">
              {String(ch.num).padStart(2, '0')}
            </span>
            <h2 class="font-heading text-2xl font-semibold text-[#1a1a2e] mb-2">{ch.name}</h2>
            <p class="text-sm text-[#6b6b7b] mb-4 flex-grow">{ch.desc}</p>
            <span class="text-xs font-semibold uppercase tracking-wider text-[#c9a96e] mt-auto">
              {ch.recipes.length} {ch.recipes.length === 1 ? 'Entry' : 'Entries'} →
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Recipe Listings -->
    <div class="space-y-24 max-w-4xl mx-auto">
      {chapters.map(ch => (
        <section id={`chapter-${ch.num}`} class="recipe-listing-section" style="scroll-margin-top: 80px;">
          <header class="mb-8 pb-4 border-b border-[#e0d8cc]">
            <h2 class="font-heading text-3xl md:text-4xl font-semibold text-[#1a1a2e]">
              Chapter {ch.num}: {ch.name}
            </h2>
          </header>

          <div class="flex flex-col gap-2">
            {ch.recipes.map(recipe => (
              <a
                href={`/${recipe.id}`}
                class="recipe-list-item group flex items-center justify-between p-4 rounded-lg bg-white/50 hover:bg-white border border-transparent hover:border-[#e0d8cc] hover:shadow-sm transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e]"
              >
                <div class="flex items-center gap-4">
                  <span class="font-mono text-sm font-semibold text-[#c9a96e] w-16 shrink-0">{recipe.data.index}</span>
                  <div class="flex items-center gap-2">
                    <span class="font-heading text-xl text-[#1a1a2e] font-medium">{recipe.data.title}</span>
                    {recipe.data.type === 'technique' && (
                      <span class="hidden sm:inline text-[10px] font-bold tracking-widest uppercase text-[#6b6b7b]/50 border border-[#e0d8cc] rounded px-1.5 py-0.5">Technique</span>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-2.5 shrink-0 ml-4">
                  {recipe.data.heroImage && (
                    <svg class="text-[#6b6b7b]/30" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="Has photo"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                  )}
                  <svg class="text-[#e0d8cc] group-hover:text-[#c9a96e] transition-colors duration-300" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </a>
            ))}
            {ch.recipes.length === 0 && (
              <p class="p-4 text-[#6b6b7b] italic">Entries coming soon.</p>
            )}
          </div>
        </section>
      ))}
    </div>

  </div>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    
    document.addEventListener('DOMContentLoaded', () => {
      gsap.registerPlugin(ScrollTrigger);
      
      // Respect prefers-reduced-motion
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        // Hero entrance
        gsap.to('.section-hero', {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: 'power3.out'
        });

        // Staggered chapter cards
        gsap.from('.chapter-card', {
          y: 50,
          opacity: 0,
          rotationX: 10,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '.grid',
            start: 'top 85%'
          }
        });
        
        // Removed recipe list item stagger animation to ensure immediate visibility without scroll lag.
      } else {
        // If reduced motion, just ensure visibility immediately
        document.querySelector('.section-hero')?.classList.remove('opacity-0', 'translate-y-8');
      }
    });
  </script>
</BaseLayout>
