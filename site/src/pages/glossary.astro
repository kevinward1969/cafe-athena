---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read and parse the glossary markdown file
const glossaryPath = path.resolve('src/content/glossary.md');
let glossaryContent = '';
try {
  glossaryContent = fs.readFileSync(glossaryPath, 'utf-8');
} catch {
  glossaryContent = '# Glossary\n\nNo glossary file found.';
}

// Parse glossary into structured data
interface GlossaryEntry {
  term: string;
  definition: string;
}

interface GlossarySection {
  letter: string;
  entries: GlossaryEntry[];
}

function normalizeTerm(raw: string): string {
  return raw
    .replace(/^\*\*|\*\*$/g, '')
    .replace(/^“|”$/g, '')
    .trim();
}

function splitTermAndDefinition(line: string): GlossaryEntry | null {
  const cleaned = line.replace(/^[-*]\s+/, '').trim();
  const colonIdx = cleaned.indexOf(':');
  if (colonIdx <= 0) return null;

  const term = normalizeTerm(cleaned.slice(0, colonIdx));
  const definition = cleaned.slice(colonIdx + 1).trim();
  if (!term || !definition) return null;

  return { term, definition };
}

function parseGlossary(content: string): GlossarySection[] {
  const lines = content.split('\n');
  const sectionsMap = new Map<string, GlossaryEntry[]>();
  let currentSection = 'Ungrouped';
  let pendingEntry: GlossaryEntry | null = null;

  const commitPending = () => {
    if (!pendingEntry) return;
    const target = sectionsMap.get(currentSection) ?? [];
    target.push({ ...pendingEntry });
    sectionsMap.set(currentSection, target);
    pendingEntry = null;
  };

  for (const rawLine of lines) {
    const line = rawLine.trim();

    if (!line) {
      commitPending();
      continue;
    }

    if (line.startsWith('## ')) {
      commitPending();
      currentSection = line.replace(/^##\s+/, '').trim();
      if (!sectionsMap.has(currentSection)) {
        sectionsMap.set(currentSection, []);
      }
      continue;
    }

    if (/^[-*]\s+/.test(line)) {
      commitPending();
      const parsed = splitTermAndDefinition(line);
      if (parsed) pendingEntry = parsed;
      continue;
    }

    // Continuation line for wrapped definitions.
    if (pendingEntry) {
      pendingEntry.definition = `${pendingEntry.definition} ${line}`.trim();
    }
  }

  commitPending();

  // Fallback for legacy single-file glossary without "##" sections.
  if (!sectionsMap.size || (sectionsMap.size === 1 && sectionsMap.has('Ungrouped'))) {
    const grouped = new Map<string, GlossaryEntry[]>();
    const allEntries = sectionsMap.get('Ungrouped') ?? [];

    for (const entry of allEntries) {
      const first = entry.term[0]?.toUpperCase() ?? '#';
      const letter = /[A-Z]/.test(first) ? first : '0-9';
      const bucket = grouped.get(letter) ?? [];
      bucket.push(entry);
      grouped.set(letter, bucket);
    }

    sectionsMap.clear();
    for (const [letter, entries] of grouped) {
      sectionsMap.set(letter, entries);
    }
  }

  const order = (value: string) => {
    if (value === '0-9') return '00';
    return value;
  };

  return Array.from(sectionsMap.entries())
    .map(([letter, entries]) => ({
      letter,
      entries: [...entries].sort((a, b) => a.term.localeCompare(b.term)),
    }))
    .sort((a, b) => order(a.letter).localeCompare(order(b.letter)));
}

const glossarySections = parseGlossary(glossaryContent);
const allLetters = glossarySections.map(s => s.letter);
const totalEntries = glossarySections.reduce((sum, section) => sum + section.entries.length, 0);
---

<BaseLayout title="Glossary" currentPage="glossary">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="page-title text-center mb-14 opacity-0 translate-y-8">
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-[#c9a96e]/80 mb-4">Culinary Index</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold text-[#1a1a2e] tracking-tight mb-4">Glossary</h1>
      <p class="font-heading text-xl md:text-2xl italic text-[#6b6b7b]">A high-density lexicon built for fast retrieval at service speed.</p>
      <div class="w-16 h-0.5 bg-[#c9a96e] mx-auto mt-6"></div>
    </div>

    <div class="glossary-shell grid lg:grid-cols-[18rem_minmax(0,1fr)] gap-10 lg:gap-12">
      <aside class="glossary-controls lg:sticky lg:top-[5.5rem] self-start rounded-2xl border border-[#e0d8cc] bg-white/70 backdrop-blur p-5 md:p-6 opacity-0">
        <div class="mb-6">
          <p class="font-mono text-[10px] tracking-[0.24em] uppercase text-[#6b6b7b]/70 mb-2">Inventory</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[#e0d8cc] bg-[#faf7f2] p-3">
              <p class="text-[11px] uppercase tracking-wider text-[#6b6b7b]">Terms</p>
              <p class="font-heading text-3xl leading-none text-[#1a1a2e]">{totalEntries}</p>
            </div>
            <div class="rounded-xl border border-[#e0d8cc] bg-[#faf7f2] p-3">
              <p class="text-[11px] uppercase tracking-wider text-[#6b6b7b]">Groups</p>
              <p class="font-heading text-3xl leading-none text-[#1a1a2e]">{glossarySections.length}</p>
            </div>
          </div>
        </div>

        <div class="relative mb-5">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-[#6b6b7b]" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <input
            type="text"
            class="w-full pl-11 pr-4 py-2.5 bg-white border border-[#e0d8cc] rounded-lg focus:outline-none focus:ring-2 focus:ring-[#c9a96e] transition-all text-[#1a1a2e] placeholder:text-[#6b6b7b]/60"
            id="glossary-search"
            placeholder="Search term or definition"
            autocomplete="off"
          />
        </div>

        <p class="text-sm text-[#6b6b7b] mb-3" id="glossary-results-summary">Showing all {totalEntries} terms</p>

        <nav class="grid grid-cols-5 sm:grid-cols-7 lg:grid-cols-5 gap-2" aria-label="Glossary group filters">
          <button
            type="button"
            data-letter-filter="ALL"
            class="letter-filter px-2 py-2 rounded-lg border border-[#c9a96e] bg-[#c9a96e] text-white text-xs font-bold tracking-wide focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e]"
          >All</button>
          {glossarySections.map(section => (
            <button
              type="button"
              data-letter-filter={section.letter}
              class="letter-filter px-2 py-2 rounded-lg border border-[#e0d8cc] bg-white text-[#1a1a2e] text-xs font-bold tracking-wide hover:border-[#c9a96e] hover:text-[#c9a96e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] transition-colors"
            >{section.letter}</button>
          ))}
        </nav>
      </aside>

      <div>
        <nav class="glossary-nav flex flex-wrap gap-2 mb-8 opacity-0" aria-label="Jump to glossary group">
          {allLetters.map(letter => (
            <a
              href={`#letter-${letter}`}
              class="px-3 py-1.5 rounded-full bg-white border border-[#e0d8cc] text-xs font-semibold text-[#1a1a2e] hover:border-[#c9a96e] hover:text-[#c9a96e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] transition-colors"
            >{letter}</a>
          ))}
        </nav>

        <div id="glossary-content" class="space-y-8">
          {glossarySections.map(section => (
            <section
              class="glossary-section rounded-2xl border border-[#e0d8cc] bg-white/70 backdrop-blur p-5 md:p-6"
              id={`letter-${section.letter}`}
              data-letter={section.letter}
              style="scroll-margin-top: 120px;"
            >
              <header class="flex items-center justify-between gap-3 border-b border-[#e0d8cc] pb-4 mb-5">
                <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#1a1a2e]">{section.letter}</h2>
                <span class="text-xs font-semibold uppercase tracking-wider text-[#6b6b7b] bg-[#faf7f2] border border-[#e0d8cc] rounded-full px-3 py-1">
                  {section.entries.length} {section.entries.length === 1 ? 'term' : 'terms'}
                </span>
              </header>

              <dl class="space-y-5">
                {section.entries.map(entry => (
                  <div class="glossary-term group" data-term={entry.term.toLowerCase()} data-definition={entry.definition.toLowerCase()}>
                    <dt class="font-heading text-xl font-semibold text-[#1a1a2e] mb-1 group-hover:text-[#c9a96e] transition-colors">{entry.term}</dt>
                    <dd class="text-[#6b6b7b] leading-relaxed pl-4 border-l-2 border-[#e0d8cc]">{entry.definition}</dd>
                  </div>
                ))}
              </dl>
            </section>
          ))}
        </div>
      </div>
    </div>

    <div id="no-results" class="hidden text-center py-16">
      <p class="font-heading text-2xl italic text-[#6b6b7b]">No matching terms found.</p>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // @ts-ignore
      const gsap = window.gsap;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion && gsap) {
        const tl = gsap.timeline();
        tl.to('.page-title', { y: 0, opacity: 1, duration: 0.8, ease: 'power3.out' })
          .to('.glossary-controls', { opacity: 1, duration: 0.5 }, "-=0.4")
          .to('.glossary-nav', { opacity: 1, duration: 0.5 }, "-=0.3");
      } else {
        document.querySelector('.page-title')?.classList.remove('opacity-0', 'translate-y-8');
        document.querySelector('.glossary-controls')?.classList.remove('opacity-0');
        document.querySelector('.glossary-nav')?.classList.remove('opacity-0');
      }

      const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
      const glossaryContent = document.getElementById('glossary-content');
      const noResults = document.getElementById('no-results');
      const summary = document.getElementById('glossary-results-summary');
      const filterButtons = document.querySelectorAll('[data-letter-filter]');
      
      if (!searchInput || !glossaryContent || !noResults || !summary) return;

      const sections = glossaryContent.querySelectorAll('.glossary-section');
      const terms = glossaryContent.querySelectorAll('.glossary-term');
      let activeFilter = 'ALL';

      const setActiveFilterButton = (value: string) => {
        filterButtons.forEach(button => {
          const el = button as HTMLButtonElement;
          const isActive = el.dataset.letterFilter === value;

          el.classList.toggle('bg-[#c9a96e]', isActive);
          el.classList.toggle('border-[#c9a96e]', isActive);
          el.classList.toggle('text-white', isActive);

          el.classList.toggle('bg-white', !isActive);
          el.classList.toggle('border-[#e0d8cc]', !isActive);
          el.classList.toggle('text-[#1a1a2e]', !isActive);
        });
      };

      const applyFilters = () => {
        const query = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        terms.forEach(termNode => {
          const termEl = termNode as HTMLElement;
          const termText = termEl.dataset.term || '';
          const defText = termEl.dataset.definition || '';
          const matchesSearch = !query || termText.includes(query) || defText.includes(query);
          termEl.classList.toggle('hidden', !matchesSearch);
          if (matchesSearch) visibleCount++;
        });

        sections.forEach(sectionNode => {
          const sectionEl = sectionNode as HTMLElement;
          const sectionLetter = sectionEl.dataset.letter || '';
          const hasVisibleTerms = sectionEl.querySelectorAll('.glossary-term:not(.hidden)').length > 0;
          const matchesLetter = activeFilter === 'ALL' || sectionLetter === activeFilter;
          const shouldShow = hasVisibleTerms && matchesLetter;
          sectionEl.classList.toggle('hidden', !shouldShow);
        });

        noResults.classList.toggle('hidden', visibleCount > 0);

        if (query) {
          summary.textContent = `Search: ${visibleCount} ${visibleCount === 1 ? 'result' : 'results'}`;
        } else if (activeFilter === 'ALL') {
          summary.textContent = `Showing all ${visibleCount} terms`;
        } else {
          summary.textContent = `${activeFilter} group: ${visibleCount} ${visibleCount === 1 ? 'term' : 'terms'}`;
        }
      };

      searchInput.addEventListener('input', applyFilters);

      filterButtons.forEach(button => {
        button.addEventListener('click', () => {
          const target = button as HTMLButtonElement;
          activeFilter = target.dataset.letterFilter || 'ALL';
          setActiveFilterButton(activeFilter);
          applyFilters();
        });
      });

      setActiveFilterButton(activeFilter);
      applyFilters();
    });
  </script>
</BaseLayout>
