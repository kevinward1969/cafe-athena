---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { buildBreadcrumbJsonLd } from '../../utils/recipeSchema';

export async function getStaticPaths() {
  const now = new Date();
  const allPosts = await getCollection('expo');
  const sorted = allPosts
    .filter(p => !p.data.publishDate || p.data.publishDate <= now)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

let heroImagePath: string | undefined;
if (post.data.heroImage) {
  heroImagePath = `/images/${post.data.heroImage}`;
}

const relatedRecipeEntries = await Promise.all(
  (post.data.relatedRecipes ?? []).map(id => getEntry('recipes', id))
);
const relatedRecipes = relatedRecipeEntries.filter(Boolean);

const breadcrumbSchema = buildBreadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'Expo', url: '/expo' },
  { name: post.data.title, url: `/expo/${post.id}` },
]);

const articleSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.excerpt,
  author: { '@type': 'Organization', name: 'Café Athena' },
  datePublished: post.data.date.toISOString(),
  url: `https://cafeathenathemanual.com/expo/${post.id}`,
};
if (post.data.heroImage) {
  articleSchema.image = `https://cafeathenathemanual.com/images/${post.data.heroImage}`;
}

const ogImage = post.data.heroImage
  ? `https://cafeathenathemanual.com/images/${post.data.heroImage}`
  : undefined;
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  currentPage="expo"
  structuredData={[breadcrumbSchema, articleSchema]}
  ogType="article"
  ogImage={ogImage}
>
  <article class="max-w-3xl mx-auto px-6 py-16 md:py-24">
    {heroImagePath && (
      <img
        src={heroImagePath}
        alt={post.data.title}
        class="w-full aspect-video object-cover mb-10 rounded-sm"
      />
    )}
    <header class="mb-10">
      <div class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#c9a96e]/60 mb-4">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.category && (
          <a
            href={`/expo/category/${post.data.category.toLowerCase().replace(/&/g, 'and').replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}`}
            class="ml-4 pl-4 border-l border-[#c9a96e]/30 hover:text-[#c9a96e] transition-colors"
          >
            {post.data.category}
          </a>
        )}
      </div>
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold italic text-[#1a1a2e] leading-tight mb-4">
        {post.data.title}
      </h1>
      {post.data.excerpt && (
        <p class="font-heading text-xl italic text-[#6b6b7b] leading-relaxed">
          {post.data.excerpt}
        </p>
      )}
    </header>
    <div
      class="prose-expo"
      data-pagefind-body
      data-pagefind-meta={`title:${post.data.title}`}
    >
      <Content />
    </div>

    {relatedRecipes.length > 0 && (
      <section class="mt-12 pt-10 border-t border-[#e0d8cc]">
        <h2 class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#c9a96e]/60 mb-6">
          Featured {relatedRecipes.length === 1 ? 'Recipe' : 'Recipes'}
        </h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {relatedRecipes.map(recipe => (
            <a
              href={`/${recipe.id}`}
              class="group flex gap-4 items-start p-4 border border-[#e0d8cc] rounded-sm hover:border-[#c9a96e]/40 transition-colors"
            >
              {recipe.data.heroImage ? (
                <img
                  src={`/images/${recipe.data.heroImage}`}
                  alt={recipe.data.title}
                  class="w-20 h-16 object-cover rounded-sm flex-shrink-0"
                />
              ) : (
                <div class="w-20 h-16 flex-shrink-0 bg-[#f0ece3] rounded-sm flex items-center justify-center">
                  <span class="font-heading text-sm font-bold text-[#1a1a2e]/20">{recipe.data.index}</span>
                </div>
              )}
              <div class="min-w-0">
                <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#6b6b7b] mb-1">
                  {recipe.data.index}
                </p>
                <p class="font-heading text-xl font-semibold text-[#1a1a2e] group-hover:text-[#c9a96e] transition-colors leading-tight">
                  {recipe.data.title}
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {post.data.tags && post.data.tags.length > 0 && (
      <footer class="mt-12 pt-8 border-t border-[#e0d8cc]">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => (
            <a
              href={`/expo/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
              class="font-mono text-[10px] uppercase tracking-widest text-[#6b6b7b] bg-[#e0d8cc]/40 hover:bg-[#c9a96e]/20 hover:text-[#c9a96e] px-3 py-1 rounded-full transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .prose-expo {
    color: #1a1a2e;
    line-height: 1.8;
    font-size: 1.0625rem;
  }

  .prose-expo :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.75rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: #1a1a2e;
  }

  .prose-expo :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1a1a2e;
  }

  .prose-expo :global(p) {
    margin-bottom: 1.5rem;
  }

  .prose-expo :global(a) {
    color: #c9a96e;
    text-decoration: underline;
    text-decoration-color: rgba(201, 169, 110, 0.4);
    text-underline-offset: 3px;
  }

  .prose-expo :global(a:hover) {
    text-decoration-color: #c9a96e;
  }

  .prose-expo :global(strong) {
    font-weight: 600;
  }

  .prose-expo :global(ul),
  .prose-expo :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose-expo :global(ul) {
    list-style-type: disc;
  }

  .prose-expo :global(ol) {
    list-style-type: decimal;
  }

  .prose-expo :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose-expo :global(blockquote) {
    border-left: 3px solid #c9a96e;
    padding-left: 1.25rem;
    margin: 2rem 0;
    color: #6b6b7b;
    font-style: italic;
  }

  .prose-expo :global(hr) {
    border: none;
    border-top: 1px solid #e0d8cc;
    margin: 2.5rem 0;
  }
</style>
