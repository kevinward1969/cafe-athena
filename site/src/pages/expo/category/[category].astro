---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function categorySlug(cat: string): string {
  return cat
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9-]/g, '');
}

export async function getStaticPaths() {
  const now = new Date();
  const allPosts = (await getCollection('expo')).filter(
    p => !p.data.publishDate || p.data.publishDate <= now
  );

  const categorySet = new Set<string>();
  for (const post of allPosts) {
    if (post.data.category) {
      categorySet.add(post.data.category);
    }
  }

  return Array.from(categorySet).map(category => {
    const slug = categorySlug(category);
    const postsInCategory = allPosts
      .filter(p => p.data.category === category)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    return {
      params: { category: slug },
      props: { category, posts: postsInCategory },
    };
  });
}

const { category, posts } = Astro.props;
---

<BaseLayout
  title={`Category: ${category}`}
  description={`Expo posts in the "${category}" category — essays, walkthroughs, and culinary explorations from Café Athena.`}
  currentPage="expo"
>
  <div class="max-w-7xl mx-auto px-6 py-16 md:py-24">
    <header class="mb-12">
      <a
        href="/expo"
        class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#c9a96e]/60 hover:text-[#c9a96e] transition-colors inline-flex items-center gap-2 mb-6"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        The Expo
      </a>
      <p class="font-mono text-[10px] uppercase tracking-[0.35em] text-[#c9a96e]/70 mb-3">Category</p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold italic text-[#1a1a2e] leading-tight">
        {category}
      </h1>
      <p class="mt-3 font-heading text-lg italic text-[#6b6b7b]">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'}
      </p>
    </header>

    {posts.length === 0 ? (
      <p class="font-heading text-xl italic text-[#6b6b7b] text-center py-16">No posts in this category.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => {
          const heroImagePath = post.data.heroImage ? `/images/${post.data.heroImage}` : null;
          return (
            <a
              href={`/expo/${post.id}`}
              class="group flex flex-col border border-[#e0d8cc] hover:border-[#c9a96e]/40 transition-all duration-300 rounded-sm overflow-hidden"
            >
              {heroImagePath && (
                <div class="aspect-video overflow-hidden bg-[#1a1a2e]/5">
                  <img
                    src={heroImagePath}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                    onerror="this.closest('[class*=aspect-video]').style.display='none'"
                  />
                </div>
              )}
              <div class="flex flex-col flex-1 p-6">
                <div class="font-mono text-[9px] uppercase tracking-[0.3em] text-[#c9a96e]/60 mb-3">
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h2 class="font-heading text-2xl font-bold italic text-[#1a1a2e] group-hover:text-[#c9a96e] transition-colors leading-snug mb-3">
                  {post.data.title}
                </h2>
                {post.data.excerpt && (
                  <p class="text-sm text-[#6b6b7b] leading-relaxed line-clamp-3 flex-1">
                    {post.data.excerpt}
                  </p>
                )}
                <div class="mt-4 pt-4 border-t border-[#e0d8cc] flex items-center gap-1 font-mono text-[9px] uppercase tracking-widest text-[#c9a96e]/60 group-hover:text-[#c9a96e] transition-colors">
                  Read
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
