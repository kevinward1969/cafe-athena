---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_GROUPS, familyToSlug } from '../../utils/taxonomy';

const allRecipes = await getCollection('recipes');

const familyData = new Map<string, { count: number; hero: string | null }>();
for (const recipe of allRecipes) {
  const f = recipe.data.family;
  if (!f) continue;
  if (!familyData.has(f)) familyData.set(f, { count: 0, hero: null });
  const entry = familyData.get(f)!;
  entry.count += 1;
  if (!entry.hero && recipe.data.heroImage) entry.hero = recipe.data.heroImage;
}

const groups = CATEGORY_GROUPS.map(group => ({
  ...group,
  items: group.families
    .filter(f => familyData.has(f))
    .map(f => ({
      family: f,
      slug: familyToSlug(f),
      count: familyData.get(f)!.count,
      hero: familyData.get(f)!.hero,
    })),
})).filter(g => g.items.length > 0);

const totalRecipes = allRecipes.length;
const totalFamilies = groups.reduce((n, g) => n + g.items.length, 0);
---

<BaseLayout title="Categories" currentPage="categories">

  <!-- Hero -->
  <section class="border-b border-[#e0d8cc]/60 py-20 px-6 text-center">
    <p class="font-mono text-[10px] uppercase tracking-[0.35em] text-[#c9a96e] mb-4">Browse the Manual</p>
    <h1 class="font-heading text-6xl md:text-8xl font-bold text-[#1a1a2e] tracking-tighter mb-5">Categories</h1>
    <p class="text-base text-[#6b6b7b]">
      {totalRecipes} recipes &nbsp;·&nbsp; {totalFamilies} categories
    </p>
  </section>

  <!-- Groups -->
  <div class="max-w-7xl mx-auto px-6">
    {groups.map((group, gi) => (
      <section class={gi > 0 ? 'border-t border-[#e0d8cc]/60' : ''}>

        <!-- Group header -->
        <div class="py-10 flex items-baseline justify-between">
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#1a1a2e]">{group.label}</h2>
          <span class="font-mono text-[9px] uppercase tracking-[0.25em] text-[#6b6b7b]/50">
            {group.items.length} {group.items.length === 1 ? 'category' : 'categories'}
          </span>
        </div>

        <!-- Card grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 pb-14">
          {group.items.map(item => (
            <a
              href={`/categories/${item.slug}`}
              class="group relative overflow-hidden rounded-sm bg-[#1a1a2e] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e]"
              style="aspect-ratio: 16/9;"
            >
              <!-- Image -->
              {item.hero ? (
                <img
                  src={`/images/${item.hero}`}
                  alt=""
                  aria-hidden="true"
                  class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-70 group-hover:scale-105 transition-all duration-500 ease-out"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 bg-gradient-to-br from-[#2a2a4e] to-[#1a1a2e]"></div>
              )}

              <!-- Gradient overlay -->
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,10,20,0.92) 0%, rgba(10,10,20,0.4) 50%, rgba(10,10,20,0.1) 100%);"></div>

              <!-- Gold left accent bar — appears on hover -->
              <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-[#c9a96e] scale-y-0 group-hover:scale-y-100 transition-transform duration-300 origin-bottom"></div>

              <!-- Text -->
              <div class="absolute inset-x-0 bottom-0 p-5">
                <p class="font-mono text-[8px] uppercase tracking-[0.3em] text-[#c9a96e]/70 mb-1.5">
                  {item.count} {item.count === 1 ? 'recipe' : 'recipes'}
                </p>
                <h3 class="font-heading text-xl md:text-2xl font-bold text-white group-hover:text-[#c9a96e] transition-colors duration-300 leading-tight">
                  {item.family}
                </h3>
              </div>

              <!-- Arrow indicator -->
              <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <svg class="text-[#c9a96e]" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>

      </section>
    ))}
  </div>

</BaseLayout>
