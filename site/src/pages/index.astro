---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allRecipes = await getCollection('recipes');

const pillars = [
  {
    id: 'academy',
    part: 'I',
    label: 'Archive 01',
    title: 'The Academy',
    subtitle: 'Technique & Theory',
    desc: 'Master the foundational theories and technical disciplines of classical gastronomy.',
    href: '/academy',
    image: '/images/section-academy.webp',
    imageAlt: "Chef's hands working over a copper pan"
  },
  {
    id: 'brigade',
    part: 'II',
    label: 'Archive 02',
    title: 'The Brigade',
    subtitle: 'The Recipe Collection',
    desc: 'A rigorous collection of codified recipes — from mother sauces to modern executions.',
    href: '/brigade',
    image: '/images/section-brigade.webp',
    imageAlt: 'Fine dining plated beef on a slate surface'
  },
  {
    id: 'larder',
    part: 'III',
    label: 'Archive 03',
    title: 'The Larder',
    subtitle: 'Building Blocks',
    desc: 'Stocks, sauces, and foundational flavor compounds. The essential pantry of the craft.',
    href: '/larder',
    image: '/images/section-larder.webp',
    imageAlt: 'Mirepoix vegetables arranged on a dark slate board'
  },
];

const highlights = [
  {
    id: '01-01',
    label: 'Technical Discipline 01',
    title: 'Thermodynamics & Heat Control',
    desc: 'The physics of thermal transfer in the kitchen. How heat moves through metal, water, and fat — and why it matters for every technique that follows.',
    href: '/01-01',
    image: '/images/01-01.png',
  },
  {
    id: '01-02',
    label: 'Technical Discipline 02',
    title: 'Salinity & Equilibrium',
    desc: 'Why salt does more than season. A study of osmosis, equilibrium brining, and how salt transforms the cellular structure of proteins before heat is ever applied.',
    href: '/01-02',
    image: '/images/01-02.png',
  },
  {
    id: '01-03',
    label: 'Technical Discipline 03',
    title: "Baker's Percentages & Hydration",
    desc: "The mathematics of dough. Understanding baker's percentages as a universal ratio system — the foundation of every bread, pasta, and pastry in this Manual.",
    href: '/01-03',
    image: '/images/01-03.png',
  },
];

const glossaryTerms = [
  {
    term: 'Mise en Place',
    phonetic: 'Noun / miːz ɑ̃ ˈplas',
    def: '"Everything in its place." The professional discipline of preparing, measuring, and organizing all ingredients before cooking begins. The foundation of kitchen efficiency.',
  },
  {
    term: 'Maillard Reaction',
    phonetic: 'Noun / maɪˈjɑːr',
    def: 'The complex series of chemical reactions between amino acids and reducing sugars that produce browned, flavored compounds when food is heated above 140°C (285°F).',
  },
  {
    term: 'Beurre Blanc',
    phonetic: 'Noun / bœʁ blɑ̃',
    def: 'A classical French emulsion sauce of reduced white wine and vinegar, finished with cold butter. An exercise in fat suspended in an acidic reduction.',
  },
  {
    term: 'Fond',
    phonetic: 'Noun / fɔ̃',
    def: 'The concentrated, caramelized residue left on a pan after searing. Rich in Maillard compounds — the foundation of every pan sauce, gravy, and jus.',
  },
];
---

<BaseLayout title="Welcome" currentPage="home">

  <!-- ── Hero ───────────────────────────────────────────────────────────── -->
  <section class="text-center w-full max-w-4xl mx-auto px-6 pt-24 pb-32 landing-hero opacity-0 translate-y-8">
    <div class="inline-block border border-[#c9a96e] px-4 py-1 rounded-full text-xs font-semibold tracking-widest uppercase text-[#c9a96e] mb-8">
      Café Athena
    </div>
    <h1 class="font-heading text-7xl md:text-8xl lg:text-9xl font-bold text-[#1a1a2e] tracking-tighter leading-none mb-8">
      The Manual
    </h1>
    <p class="font-heading text-2xl md:text-3xl italic text-[#6b6b7b] max-w-2xl mx-auto mb-10">
      A living codex of technique, science, and culinary soul.
    </p>
    <div class="flex items-center justify-center gap-4 mb-12">
      <span class="h-px w-12 bg-[#e0d8cc]"></span>
      <span class="font-mono text-sm font-semibold text-[#c9a96e] tracking-[0.2em]">{allRecipes.length} entries</span>
      <span class="h-px w-12 bg-[#e0d8cc]"></span>
    </div>
    <a
      href="/academy"
      class="inline-flex items-center gap-3 bg-[#1a1a2e] text-[#f5f0e8] px-8 py-4 font-mono text-[11px] uppercase tracking-[0.2em] hover:bg-[#c9a96e] hover:text-[#1a1a2e] transition-colors duration-300 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e]"
    >
      Explore the Manual
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </section>

  <!-- ── Three Pillar Cards ─────────────────────────────────────────────── -->
  <section class="border-t border-[#e0d8cc]/60">
    <div class="grid grid-cols-1 md:grid-cols-3">
      {pillars.map((pillar, i) => (
        <a
          href={pillar.href}
          class={`landing-card opacity-0 group relative overflow-hidden flex flex-col justify-end p-10 lg:p-14 transition-all duration-700 no-underline focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-inset focus-visible:ring-[#c9a96e] ${i < pillars.length - 1 ? 'md:border-r border-[#e0d8cc]/60' : ''}`}
          style="aspect-ratio: 3/4; min-height: 520px;"
        >
          <!-- Background photo -->
          <img
            src={pillar.image}
            alt={pillar.imageAlt}
            class="absolute inset-0 w-full h-full object-cover grayscale opacity-20 group-hover:opacity-50 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out"
            loading="lazy"
            decoding="async"
          />

          <!-- Surface overlay — fades out on hover to reveal photo -->
          <div class="absolute inset-0 bg-[#faf7f2] opacity-70 group-hover:opacity-0 transition-opacity duration-700"></div>

          <!-- Dark gradient — appears on hover to protect text against photo -->
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700" style="background: linear-gradient(to top, rgba(10,10,20,0.90) 0%, rgba(10,10,20,0.5) 55%, rgba(10,10,20,0.0) 100%);"></div>

          <!-- Content -->
          <div class="relative z-10">
            <span class="font-mono text-[10px] uppercase tracking-[0.25em] text-[#6b6b7b] group-hover:text-[#c9a96e]/80 mb-5 block transition-colors duration-500">
              {pillar.label}
            </span>
            <h2 class="font-heading text-5xl lg:text-6xl font-bold text-[#1a1a2e] group-hover:text-white mb-3 transition-colors duration-500 leading-tight">
              {pillar.title}
            </h2>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#c9a96e] mb-6">{pillar.subtitle}</p>

            <!-- Description — hidden until hover -->
            <p class="text-[#f5f0e8] text-base leading-relaxed max-w-xs mb-8 opacity-0 translate-y-3 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 delay-75">
              {pillar.desc}
            </p>

            <!-- Expanding line -->
            <div class="h-px bg-[#1a1a2e] group-hover:bg-[#c9a96e] w-12 group-hover:w-full transition-all duration-700 ease-out"></div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Highlights from The Academy ──────────────────────────────────── -->
  <section class="bg-[#faf7f2] py-24 px-6 md:px-12 border-t border-[#e0d8cc]/60">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#6b6b7b] mb-3 block">Archive Insights</span>
        <h2 class="font-heading text-5xl md:text-6xl font-bold text-[#1a1a2e]">Highlights from The Academy</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16">
        {highlights.map(h => (
          <a href={h.href} class="group block focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm">
            <div class="aspect-video overflow-hidden bg-[#e0d8cc] mb-7 rounded-sm">
              <img
                src={h.image}
                alt={h.title}
                class="w-full h-full object-cover grayscale brightness-90 group-hover:scale-105 group-hover:grayscale-0 transition-all duration-700"
                loading="lazy"
                decoding="async"
              />
            </div>
            <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-[#6b6b7b] mb-2 block">{h.label}</span>
            <h3 class="font-heading text-2xl font-bold text-[#1a1a2e] group-hover:text-[#c9a96e] transition-colors duration-300 mb-3 leading-snug">{h.title}</h3>
            <p class="text-[#6b6b7b] text-base leading-relaxed">{h.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Featured Recipe ────────────────────────────────────────────────── -->
  <section class="border-t border-[#e0d8cc]/60 flex flex-col lg:flex-row min-h-[600px]">
    <!-- Image -->
    <div class="w-full lg:w-2/3 relative min-h-[420px] overflow-hidden">
      <img
        src="/images/07-04.png"
        alt="Beef Bourguignon — The Elevated Short Rib Braise"
        class="w-full h-full object-cover brightness-75"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute top-10 left-10 bg-[#1a1a2e] px-4 py-2">
        <span class="font-mono text-[10px] text-[#c9a96e] uppercase tracking-[0.3em]">Featured Recipe</span>
      </div>
    </div>

    <!-- Editorial text -->
    <div class="w-full lg:w-1/3 bg-[#f0ede9] px-12 py-16 flex flex-col justify-center">
      <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-[#6b6b7b] mb-4 block">Synthesis of Archives</span>
      <h2 class="font-heading text-4xl lg:text-5xl font-bold text-[#1a1a2e] mb-8 leading-tight">
        Beef Bourguignon<br/>
        <span class="font-normal italic text-[#6b6b7b] text-3xl">The Elevated Short Rib Braise</span>
      </h2>
      <p class="text-[#6b6b7b] text-lg leading-relaxed mb-10">
        The definitive French braise. Short ribs rendered in Burgundy wine with lardons, pearl onions, and mushrooms — executed here with modern precision and classical discipline.
      </p>

      <div class="space-y-5 mb-12">
        <div class="flex flex-col border-b border-[#e0d8cc] pb-4">
          <span class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#6b6b7b] mb-1">From The Brigade</span>
          <span class="font-heading italic text-lg text-[#1a1a2e]">Braised Short Rib in Burgundy Reduction</span>
        </div>
        <div class="flex flex-col border-b border-[#e0d8cc] pb-4">
          <span class="font-mono text-[9px] uppercase tracking-[0.1em] text-[#6b6b7b] mb-1">From The Larder</span>
          <span class="font-heading italic text-lg text-[#1a1a2e]">Pressure-Roasted Brown Stock (Fond Brun)</span>
        </div>
      </div>

      <a
        href="/07-04"
        class="inline-flex items-center gap-4 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm"
      >
        <span class="font-mono text-[11px] uppercase tracking-[0.2em] font-bold text-[#1a1a2e] group-hover:text-[#c9a96e] transition-colors duration-300">Access the Full Dossier</span>
        <svg class="group-hover:translate-x-2 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- ── Glossary Preview ───────────────────────────────────────────────── -->
  <section class="bg-[#faf7f2] py-24 px-6 md:px-24 border-t border-[#e0d8cc]/60">
    <div class="max-w-4xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-14 border-b border-[#1a1a2e]/10 pb-8">
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-[#6b6b7b] mb-2 block">Reference Material</span>
          <h2 class="font-heading text-4xl font-bold text-[#1a1a2e]">The Glossary</h2>
        </div>
        <a
          href="/glossary"
          class="font-mono text-[10px] uppercase tracking-[0.2em] border-b border-[#1a1a2e] pb-1 hover:text-[#c9a96e] hover:border-[#c9a96e] transition-colors duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#c9a96e] rounded-sm mt-4 md:mt-0"
        >
          View Full Lexicon
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-24 gap-y-12">
        {glossaryTerms.map(entry => (
          <div>
            <h3 class="font-heading text-2xl italic font-bold text-[#1a1a2e] mb-1">{entry.term}</h3>
            <p class="font-mono text-[10px] uppercase tracking-widest text-[#6b6b7b]/60 mb-3">{entry.phonetic}</p>
            <p class="text-[#6b6b7b] leading-relaxed">{entry.def}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    a.landing-card {
      text-decoration: none;
      color: inherit;
    }
  </style>

  <script>
    import { gsap } from 'gsap';

    document.addEventListener('DOMContentLoaded', () => {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        gsap.set('.landing-card', { y: 50 });
        const tl = gsap.timeline();

        tl.to('.landing-hero', {
          y: 0,
          opacity: 1,
          duration: 1.2,
          ease: 'power3.out'
        })
        .to('.landing-card', {
          y: 0,
          opacity: 1,
          duration: 0.9,
          stagger: 0.12,
          ease: 'power3.out'
        }, '-=0.6');
      } else {
        document.querySelector('.landing-hero')?.classList.remove('opacity-0', 'translate-y-8');
        document.querySelectorAll('.landing-card').forEach(el => el.classList.remove('opacity-0'));
      }
    });
  </script>

</BaseLayout>
