---
import RecipeLayout from '../layouts/RecipeLayout.astro';
import { getCollection, render } from 'astro:content';
import { buildRecipeJsonLd } from '../utils/recipeSchema';

export async function getStaticPaths() {
  const allRecipes = await getCollection('recipes');
  const allExpo = await getCollection('expo');
  const sorted = allRecipes.sort((a, b) => a.data.index.localeCompare(b.data.index));

  return sorted.map((recipe, idx) => {
    const prev = idx > 0 ? sorted[idx - 1] : null;
    const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

    const relatedExpoPosts = allExpo
      .filter(post => post.data.relatedRecipes.includes(recipe.data.index))
      .map(p => ({ id: p.id, title: p.data.title }));

    return {
      params: { slug: recipe.id },
      props: {
        recipe,
        prevRecipe: prev ? { slug: prev.id, title: prev.data.title } : null,
        nextRecipe: next ? { slug: next.id, title: next.data.title } : null,
        relatedExpoPosts,
      },
    };
  });
}

const { recipe, prevRecipe, nextRecipe, relatedExpoPosts } = Astro.props;
const { Content } = await render(recipe);

// Resolve hero image path
let heroImagePath: string | undefined;
if (recipe.data.heroImage) {
  heroImagePath = `/images/${recipe.data.heroImage}`;
}

const recipeSchema = buildRecipeJsonLd({
  type: recipe.data.type,
  title: recipe.data.title,
  body: recipe.body ?? '',
  heroImage: recipe.data.heroImage,
  cuisine: recipe.data.cuisine,
  course: recipe.data.course,
  keywords: recipe.data.keywords,
});
---

<RecipeLayout
  title={recipe.data.title}
  index={recipe.data.index}
  chapter={recipe.data.chapter}
  chapterName={recipe.data.chapterName}
  heroImage={heroImagePath}
  subtitle={recipe.data.subtitle}
  keywords={recipe.data.keywords}
  cuisine={recipe.data.cuisine}
  style={recipe.data.style}
  family={recipe.data.family}
  course={recipe.data.course}
  dietary={recipe.data.dietary}
  recipeType={recipe.data.type}
  prevRecipe={prevRecipe}
  nextRecipe={nextRecipe}
  recipeSchema={recipeSchema}
  relatedExpoPosts={relatedExpoPosts}
>
  <Content />
</RecipeLayout>
