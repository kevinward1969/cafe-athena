# ============================================================
# Café Athena — Cache Control
#
# Purpose: guarantee recipe pages and search always show the
# latest content on devices that cache aggressively and cannot
# be cleared manually (Samsung smart-fridge browser is the
# primary target). Fingerprinted build assets are still cached
# forever for speed.
#
# How it works:
#   - HTML and the Pagefind entry manifest share stable URLs but
#     change content on every deploy -> never cache, always fetch.
#   - Files in /_astro/ and Pagefind index data are content-hash
#     named (filename changes when content changes) -> cache
#     forever, immutable.
#   - Hero/reference images reuse the same URL when re-arted ->
#     revalidate (cheap 304 when unchanged, fresh when replaced).
# ============================================================

<IfModule mod_headers.c>

  # --- Always fresh: HTML pages -------------------------------
  <FilesMatch "\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # --- Always fresh: Pagefind search manifest -----------------
  # pagefind-entry.json points at the current (hashed) index files.
  # If it goes stale, search silently serves old results.
  <FilesMatch "pagefind-entry\.json$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # --- Cache forever: fingerprinted build assets --------------
  # Astro hashes these (e.g. BaseLayout.BQjIzZ7J.css); the URL
  # changes whenever the content changes, so this is always safe.
  <FilesMatch "\.(js|css|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # --- Cache forever: Pagefind content-addressed index data ---
  <FilesMatch "\.(pf_meta|pf_fragment|pf_index|pagefind|wasm)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # --- Revalidate: images reuse stable URLs -------------------
  <FilesMatch "\.(webp|png|jpe?g|gif|svg|ico)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

</IfModule>
